# ─── OS / Editor ─────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
!.vscode/settings.json
.idea/

# ─── Source originaux (gardés en local seulement) ───
# Décommente si tu préfères ne pas pousser les .odt/.docx originaux
# *.odt
# *.docx

# ─── Scratch / extraction ────────────────────
_extracted/
_godot/
*.tmp

# ─── Godot project (game/) ────────────────────
# Sources GDScript et scènes sont commit, mais les artefacts non
game/.godot/
game/.import/
game/export/
game/*.translation
game/*.tmp

# ─── Godot HTML5 export output (regenerated per export) ───
# Si tu veux que Vercel serve le jeu via Vercel build,
# enlève la ligne ci-dessous et commit l'export.
# Pour l'instant : exporter manuellement depuis Godot puis push.
# webapp/public/godot/

# ─── Dépendances (webapp) ────────────────────
webapp/node_modules/
webapp/.pnp.*
webapp/.yarn/*
!webapp/.yarn/patches
!webapp/.yarn/plugins
!webapp/.yarn/releases
!webapp/.yarn/versions

# ─── Build outputs (webapp) ──────────────────
webapp/.next/
webapp/out/
webapp/build/
webapp/dist/
webapp/*.tsbuildinfo
webapp/next-env.d.ts

# ─── Tests / Coverage ────────────────────────
webapp/coverage/

# ─── Logs ────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Env / Secrets ───────────────────────────
.env
.env.*
!.env.example
webapp/.env
webapp/.env.*
!webapp/.env.example

# ─── Cache ───────────────────────────────────
.turbo/
.cache/
.eslintcache
.stylelintcache

# ─── Local agent context ─────────────────────
CLAUDE.md
AGENTS.md
.claude/
